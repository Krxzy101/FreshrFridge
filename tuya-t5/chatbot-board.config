# T5 AI 3.5" LCD — Tuya emoji UI + settings (swipe down) + WiFi + voice + English
CONFIG_PROJECT_VERSION="1.0.1"
CONFIG_ENABLE_AI_LANGUAGE_ENGLISH=y
# CONFIG_ENABLE_AI_UI_TEXT_STREAMING is not set
CONFIG_ENABLE_CHAT_DISPLAY2=y
CONFIG_ENABLE_GUI2_CHATBOT=y
# CONFIG_ENABLE_AI_CHAT_GUI_WECHAT is not set
# CONFIG_ENABLE_AI_CHAT_GUI_CHATBOT is not set
CONFIG_ENABLE_COMP_AI_DISPLAY=y
CONFIG_ENABLE_COMP_AI_AUDIO_CODEC_OPUS=y
CONFIG_ENABLE_TUYA_CODEC_OPUS=y
CONFIG_BUTTON_NAME="ai_chat_button"
CONFIG_BOARD_CHOICE_T5AI=y
CONFIG_TUYA_T5AI_BOARD_EX_MODULE_35565LCD=y
CONFIG_ENABLE_MBEDTLS_SSL_MAX_CONTENT_LEN=4096
CONFIG_LVGL_ENABLE_TP=y
CONFIG_ENABLE_LIBLVGL=y
