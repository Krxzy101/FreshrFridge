# 3.5" LCD + DVP camera (T5 AI board with camera module)
# Copy product credentials from your Tuya IoT project when you connect cloud.

CONFIG_PROJECT_VERSION="1.0.0"
CONFIG_BOARD_CHOICE_T5AI=y
CONFIG_TUYA_T5AI_BOARD_EX_MODULE_35565LCD=y
CONFIG_ENABLE_LIBLVGL=y
CONFIG_LVGL_ENABLE_TP=y

# Enable FreshrFridge camera hooks in camera_scan_stub.c
# Also ensure the board package registers CAMERA_NAME (see Tuya Wukong / your_chat_bot board).
CONFIG_FRESHR_CAMERA=y
